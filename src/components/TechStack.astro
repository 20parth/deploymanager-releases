---
const stack = [
  { name: 'Express.js', role: 'Backend API', color: 'text-slate-300', icon: '⚡' },
  { name: 'TypeScript', role: 'Type safety', color: 'text-blue-400', icon: '🔷' },
  { name: 'Prisma ORM', role: 'Database layer', color: 'text-teal-400', icon: '🔺' },
  { name: 'PostgreSQL 16', role: 'Database', color: 'text-sky-400', icon: '🐘' },
  { name: 'React 18', role: 'Frontend UI', color: 'text-cyan-400', icon: '⚛️' },
  { name: 'Vite', role: 'Build tooling', color: 'text-yellow-400', icon: '⚡' },
  { name: 'TanStack Query', role: 'Server state', color: 'text-red-400', icon: '🔴' },
  { name: 'Zustand', role: 'Client state', color: 'text-orange-400', icon: '🐻' },
  { name: 'Socket.io', role: 'Real-time logs', color: 'text-white', icon: '🔌' },
  { name: 'JWT + bcrypt', role: 'Auth', color: 'text-violet-400', icon: '🔐' },
  { name: 'Tailwind CSS v4', role: 'Styling', color: 'text-sky-300', icon: '🎨' },
  { name: 'Docker Compose', role: 'Containers', color: 'text-blue-500', icon: '🐳' },
];
---

<section id="tech" class="relative py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14 section-fade">
      <span class="inline-block text-violet-400 text-xs font-bold uppercase tracking-[0.2em] mb-4">Stack</span>
      <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight">
        Built on <span class="gradient-text">battle-tested tech</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-xl mx-auto">
        No exotic dependencies. If you've shipped a Node.js app before, this stack is familiar.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 section-fade">
      {stack.map(({ name, role, color, icon }) => (
        <div class="tech-card glass rounded-xl p-4 flex flex-col gap-2 cursor-default transition-all duration-200 hover:-translate-y-1">
          <div class="flex items-center gap-2">
            <span class="text-lg">{icon}</span>
            <span class={`text-sm font-semibold ${color}`}>{name}</span>
          </div>
          <span class="text-xs text-slate-500">{role}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.tech-card', {
    opacity: 0,
    y: 24,
    scale: 0.95,
    duration: 0.5,
    stagger: 0.045,
    ease: 'power2.out',
    scrollTrigger: {
      trigger: '#tech',
      start: 'top 75%',
      toggleActions: 'play none none none',
    },
  });
</script>
