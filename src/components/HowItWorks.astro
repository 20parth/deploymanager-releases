---
const steps = [
  {
    num: '01',
    icon: '🔗',
    title: 'Create a Webhook',
    desc: 'In DeployManager, create a new webhook for your project. Choose your framework template, set the git repo path, deploy path, and target branch.',
    code: 'Projects → New Webhook → copy URL + secret',
    color: 'violet',
  },
  {
    num: '02',
    icon: '⚙️',
    title: 'Add to GitHub / GitLab',
    desc: 'Paste the webhook URL and secret into your repository settings. DeployManager supports both push and pull_request events.',
    code: 'Repo Settings → Webhooks → Add webhook',
    color: 'blue',
  },
  {
    num: '03',
    icon: '🚀',
    title: 'Push to Your Branch',
    desc: 'Push a commit to your configured branch. DeployManager instantly receives the webhook, verifies the HMAC-SHA256 signature, and fires your deploy script.',
    code: 'git push origin main',
    color: 'emerald',
  },
  {
    num: '04',
    icon: '📺',
    title: 'Watch Logs Stream Live',
    desc: 'Open the deployment in your dashboard and watch every output line appear in real time. Green means live. Get a notification when it finishes.',
    code: 'Dashboard → Deployments → Live logs',
    color: 'cyan',
  },
];

const colorMap: Record<string, string> = {
  violet: 'bg-violet-500/10 border-violet-500/25 text-violet-300',
  blue:   'bg-blue-500/10 border-blue-500/25 text-blue-300',
  emerald:'bg-emerald-500/10 border-emerald-500/25 text-emerald-300',
  cyan:   'bg-cyan-500/10 border-cyan-500/25 text-cyan-300',
};
const numColor: Record<string, string> = {
  violet: 'text-violet-500/40',
  blue:   'text-blue-500/40',
  emerald:'text-emerald-500/40',
  cyan:   'text-cyan-500/40',
};
---

<section id="how-it-works" class="relative py-28 px-6 overflow-hidden">
  <!-- Ambient glow -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] pointer-events-none"
    style="background: radial-gradient(ellipse, rgba(99,102,241,0.07) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-20 section-fade">
      <span class="inline-block text-violet-400 text-xs font-bold uppercase tracking-[0.2em] mb-4">How it works</span>
      <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight">
        Live in <span class="gradient-text">4 steps</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-xl mx-auto">
        From a fresh VPS to automatic git-triggered deploys in under 10 minutes.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {steps.map((step, i) => (
        <div
          class={`hiw-step rounded-2xl border p-7 flex flex-col gap-4 relative overflow-hidden ${colorMap[step.color]}`}
          style={`--delay: ${i * 0.13}s`}
        >
          <!-- Big number watermark -->
          <span class={`absolute -top-3 -right-1 text-8xl font-black select-none pointer-events-none ${numColor[step.color]}`}>
            {step.num}
          </span>

          <div class="flex items-center gap-3">
            <span class="text-2xl">{step.icon}</span>
            <h3 class="text-lg font-semibold text-white">{step.title}</h3>
          </div>

          <p class="text-sm text-slate-400 leading-relaxed">{step.desc}</p>

          <div class="mt-auto font-mono text-xs bg-black/30 rounded-lg px-3 py-2 text-slate-400 border border-white/6">
            {step.code}
          </div>

          {i < steps.length - 1 && (
            <div class="hiw-arrow hidden lg:block absolute -right-4 top-1/2 -translate-y-1/2 z-10 text-slate-700">
              <!-- Only shows between horizontal pairs, decorative -->
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Flow diagram (desktop) -->
    <div class="hidden lg:flex items-center justify-center gap-0 mt-16 section-fade">
      {['git push', 'GitHub Webhook', 'HMAC Verified', 'Script Runs', 'Logs Stream Live ✓'].map((label, i, arr) => (
        <div class="flex items-center">
          <div class={`px-4 py-2 rounded-lg text-sm font-medium border transition-colors ${
            i === arr.length - 1
              ? 'bg-emerald-500/10 border-emerald-500/25 text-emerald-300'
              : 'bg-white/4 border-white/10 text-slate-300'
          }`}>
            {label}
          </div>
          {i < arr.length - 1 && (
            <div class="hiw-flow-arrow w-10 flex items-center justify-center text-slate-700">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Stagger the step cards
  gsap.from('.hiw-step', {
    opacity: 0,
    y: 40,
    duration: 0.7,
    stagger: 0.13,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '#how-it-works',
      start: 'top 72%',
      toggleActions: 'play none none none',
    },
  });

  // Animate the flow arrows sequentially
  gsap.from('.hiw-flow-arrow', {
    opacity: 0,
    x: -8,
    duration: 0.4,
    stagger: 0.15,
    ease: 'power2.out',
    scrollTrigger: {
      trigger: '.hiw-flow-arrow',
      start: 'top 88%',
      toggleActions: 'play none none none',
    },
  });
</script>
