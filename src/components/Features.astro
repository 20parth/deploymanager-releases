---

<!-- Live terminal log lines (rendered server-side, animated client-side) -->
<div id="live-log" class="hidden">
  <div class="log-line flex gap-2 text-xs font-mono leading-relaxed">
    <span class="text-slate-600 shrink-0 w-16">09:14:01</span>
    <span class="text-slate-400">Received webhook from <span class="text-violet-400">github.com/acme/webapp</span></span>
  </div>
  <div class="log-line flex gap-2 text-xs font-mono leading-relaxed">
    <span class="text-slate-600 shrink-0 w-16">09:14:01</span>
    <span class="text-slate-400">HMAC-SHA256 signature <span class="text-emerald-400">✓ verified</span></span>
  </div>
  <div class="log-line flex gap-2 text-xs font-mono leading-relaxed">
    <span class="text-slate-600 shrink-0 w-16">09:14:01</span>
    <span class="text-slate-400">Branch: <span class="text-cyan-400">main</span> · push by <span class="text-violet-400">@20parth</span></span>
  </div>
  <div class="log-line flex gap-2 text-xs font-mono leading-relaxed">
    <span class="text-slate-600 shrink-0 w-16">09:14:02</span>
    <span class="text-slate-400">Running deploy script...</span>
  </div>
  <div class="log-line flex gap-2 text-xs font-mono leading-relaxed">
    <span class="text-slate-600 shrink-0 w-16">09:14:03</span>
    <span class="text-slate-400">git pull origin main <span class="text-emerald-400">✓</span></span>
  </div>
  <div class="log-line flex gap-2 text-xs font-mono leading-relaxed">
    <span class="text-slate-600 shrink-0 w-16">09:14:05</span>
    <span class="text-slate-400">pnpm install --frozen-lockfile <span class="text-emerald-400">✓</span></span>
  </div>
  <div class="log-line flex gap-2 text-xs font-mono leading-relaxed">
    <span class="text-slate-600 shrink-0 w-16">09:14:18</span>
    <span class="text-slate-400">pnpm run build <span class="text-emerald-400">✓</span> (13.4s)</span>
  </div>
  <div class="log-line flex gap-2 text-xs font-mono leading-relaxed">
    <span class="text-slate-600 shrink-0 w-16">09:14:19</span>
    <span class="text-slate-400">cp -r dist/* /var/www/webapp/ <span class="text-emerald-400">✓</span></span>
  </div>
  <div class="log-line flex gap-2 text-xs font-mono leading-relaxed">
    <span class="text-slate-600 shrink-0 w-16">09:14:19</span>
    <span class="text-slate-400">nginx -s reload <span class="text-emerald-400">✓</span></span>
  </div>
  <div class="log-line flex gap-2 text-xs font-mono leading-relaxed pt-1">
    <span class="text-slate-600 shrink-0 w-16">09:14:19</span>
    <span class="text-emerald-400 font-semibold">✅ Deployment successful · 18.2s</span>
  </div>
</div>

<section id="features" class="relative py-28 px-6">
  <!-- Subtle grid bg -->
  <div class="absolute inset-0 grid-bg opacity-60 pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16 section-fade">
      <span class="inline-block text-violet-400 text-xs font-bold uppercase tracking-[0.2em] mb-4">Features</span>
      <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight">
        Everything you need to<br /><span class="gradient-text">ship faster</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-xl mx-auto">
        Production-grade deployment tooling — without the enterprise price tag.
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">

      <!-- Big card: Real-time logs (spans 2 cols × 2 rows on lg) -->
      <div
        id="feature-terminal-card"
        class="feature-card lg:col-span-2 lg:row-span-2 rounded-2xl glow-border p-6 flex flex-col gap-4 min-h-[340px]"
      >
        <div class="flex items-start gap-4">
          <div class="shrink-0 w-11 h-11 rounded-xl bg-violet-600/15 border border-violet-500/20 flex items-center justify-center text-xl">
            📊
          </div>
          <div>
            <h3 class="text-lg font-semibold text-white mb-1">Real-time Log Streaming</h3>
            <p class="text-slate-400 text-sm leading-relaxed">
              Watch every output line of your deploy script stream live in the browser via Socket.io. No more SSH-ing into the server to check if it worked.
            </p>
          </div>
        </div>

        <!-- Live terminal replay -->
        <div class="flex-1 terminal-window overflow-hidden">
          <div class="terminal-bar">
            <span class="terminal-dot bg-red-500/60"></span>
            <span class="terminal-dot bg-yellow-500/60"></span>
            <span class="terminal-dot bg-green-500/60"></span>
            <span class="ml-3 text-xs text-slate-500 font-mono">Live Deployment Log</span>
            <span class="ml-auto flex items-center gap-1.5 text-xs text-emerald-400">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse-dot"></span>
              running
            </span>
          </div>
          <div id="log-container" class="p-4 space-y-0.5 overflow-y-auto max-h-52">
          </div>
        </div>
      </div>

      <!-- Git-triggered deploys -->
      <div class="feature-card rounded-2xl glow-border p-6 flex flex-col gap-3">
        <div class="w-11 h-11 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-xl">
          🔄
        </div>
        <h3 class="text-base font-semibold text-white">Git-triggered Deploys</h3>
        <p class="text-slate-400 text-sm leading-relaxed flex-1">
          Push to a branch → webhook fires → deploy script runs automatically. Supports GitHub and GitLab with HMAC-SHA256 signature verification.
        </p>
        <div class="mt-auto font-mono text-xs text-slate-600 bg-black/30 rounded-lg px-3 py-2 border border-white/5">
          <span class="text-slate-500">git push origin </span>
          <span class="text-emerald-400">main</span>
          <span class="text-slate-600"> → deploy ⚡</span>
        </div>
      </div>

      <!-- 7 templates -->
      <div class="feature-card rounded-2xl glow-border p-6 flex flex-col gap-3">
        <div class="w-11 h-11 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-xl">
          🏗️
        </div>
        <h3 class="text-base font-semibold text-white">7 Framework Templates</h3>
        <p class="text-slate-400 text-sm leading-relaxed flex-1">
          Pre-built bash deploy scripts for React/Vite, Vue/Vite, Node.js/Express, PHP, Python, Static sites, and fully custom bash.
        </p>
        <div class="mt-auto flex flex-wrap gap-1.5">
          {['React', 'Vue', 'Node.js', 'PHP', 'Python', 'Static', 'Custom'].map(t => (
            <span class="text-xs px-2 py-0.5 rounded-md bg-white/5 border border-white/8 text-slate-400">{t}</span>
          ))}
        </div>
      </div>

      <!-- Secure webhooks -->
      <div class="feature-card rounded-2xl glow-border p-6 flex flex-col gap-3">
        <div class="w-11 h-11 rounded-xl bg-yellow-500/10 border border-yellow-500/20 flex items-center justify-center text-xl">
          🔐
        </div>
        <h3 class="text-base font-semibold text-white">Secure Webhooks</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Every incoming webhook is verified with HMAC-SHA256 before anything runs. Arbitrary code execution is impossible without the secret.
        </p>
      </div>

      <!-- Role-based access -->
      <div class="feature-card rounded-2xl glow-border p-6 flex flex-col gap-3">
        <div class="w-11 h-11 rounded-xl bg-rose-500/10 border border-rose-500/20 flex items-center justify-center text-xl">
          👥
        </div>
        <h3 class="text-base font-semibold text-white">Role-based Access</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          ADMIN, DEVELOPER, and VIEWER roles. Developers can trigger deploys; viewers can watch logs; only admins manage users.
        </p>
        <div class="mt-auto flex gap-2">
          {[['ADMIN', 'violet'], ['DEV', 'emerald'], ['VIEWER', 'slate']].map(([r, c]) => (
            <span class={`text-xs px-2.5 py-0.5 rounded-full bg-${c}-500/10 border border-${c}-500/20 text-${c}-400 font-medium`}>{r}</span>
          ))}
        </div>
      </div>

      <!-- Docker ready -->
      <div class="feature-card rounded-2xl glow-border p-6 flex flex-col gap-3">
        <div class="w-11 h-11 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-xl">
          🐳
        </div>
        <h3 class="text-base font-semibold text-white">Docker Ready</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Pull pre-built images from Docker Hub — no local build needed. Full Docker Compose setup or bare metal with PM2 + Nginx.
        </p>
        <div class="mt-auto font-mono text-xs text-slate-600 bg-black/30 rounded-lg px-3 py-2 border border-white/5">
          <span class="text-blue-400">docker</span>
          <span class="text-slate-400"> compose up -d</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .log-line {
    opacity: 0;
    transform: translateY(4px);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Animate feature cards in on scroll
  gsap.from('.feature-card', {
    opacity: 0,
    y: 36,
    duration: 0.7,
    stagger: 0.09,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '#features',
      start: 'top 75%',
      toggleActions: 'play none none none',
    },
  });

  // Animate live log lines when terminal card enters view
  const logTemplate = document.getElementById('live-log');
  const logContainer = document.getElementById('log-container');

  if (logTemplate && logContainer) {
    const logLines = Array.from(logTemplate.querySelectorAll('.log-line'));

    function playLogs() {
      logContainer!.innerHTML = '';
      logLines.forEach((line, i) => {
        const clone = line.cloneNode(true) as HTMLElement;
        clone.style.opacity = '0';
        clone.style.transform = 'translateY(4px)';
        logContainer!.appendChild(clone);
        gsap.to(clone, {
          opacity: 1,
          y: 0,
          duration: 0.35,
          delay: i * 0.42,
          ease: 'power2.out',
          onComplete: () => {
            // Auto-scroll log container
            logContainer!.scrollTop = logContainer!.scrollHeight;
          },
        });
      });
    }

    ScrollTrigger.create({
      trigger: '#feature-terminal-card',
      start: 'top 72%',
      onEnter: playLogs,
      onLeaveBack: () => {
        // reset so it replays next time
        logContainer!.innerHTML = '';
      },
    });
  }
</script>
