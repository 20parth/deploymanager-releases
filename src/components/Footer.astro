---
const year = new Date().getFullYear();

const links = {
  Project: [
    { label: 'GitHub', href: 'https://github.com/20parth/deploymanager-releases', external: true },
    { label: 'Releases', href: 'https://github.com/20parth/deploymanager-releases/releases', external: true },
    { label: 'Changelog', href: 'https://github.com/20parth/deploymanager-releases/blob/main/CHANGELOG.md', external: true },
    { label: 'Contributing', href: 'https://github.com/20parth/deploymanager-releases/blob/main/CONTRIBUTING.md', external: true },
  ],
  Install: [
    { label: 'Docker setup', href: '#install' },
    { label: 'Bare metal', href: '#install' },
    { label: 'Quick install', href: '#install' },
    { label: 'Requirements', href: '#install' },
  ],
  Author: [
    { label: 'Portfolio', href: 'https://parthrb.dev', external: true },
    { label: 'GitHub', href: 'https://github.com/20parth', external: true },
  ],
};
---

<footer class="relative border-t border-white/[0.06] pt-16 pb-10 px-6">
  <!-- Top fade -->
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-violet-500/20 to-transparent" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-14">

      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1 flex flex-col gap-4">
        <a href="/" class="flex items-center gap-2 font-bold text-lg w-fit">
          <div class="w-7 h-7 rounded-lg bg-violet-600 flex items-center justify-center text-xs font-black shadow-lg shadow-violet-600/30">
            ⚡
          </div>
          <span class="text-white">Deploy<span class="text-violet-400">Manager</span></span>
        </a>
        <p class="text-sm text-slate-500 leading-relaxed max-w-52">
          Self-hosted CI/CD for freelancers and small teams. Your server, your rules.
        </p>
        <div class="flex items-center gap-2 text-xs text-slate-600">
          <span class="px-2 py-0.5 rounded bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 font-medium">MIT</span>
          <span>v2.0.1</span>
        </div>
      </div>

      <!-- Link columns -->
      {Object.entries(links).map(([heading, items]) => (
        <div class="flex flex-col gap-3">
          <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest">{heading}</h4>
          <ul class="space-y-2.5">
            {items.map(({ label, href, external }) => (
              <li>
                <a
                  href={href}
                  target={external ? '_blank' : undefined}
                  rel={external ? 'noopener' : undefined}
                  class="text-sm text-slate-500 hover:text-slate-200 transition-colors duration-150"
                >
                  {label}
                  {external && <span class="text-slate-700 ml-0.5 text-xs">↗</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 border-t border-white/[0.05]">
      <p class="text-sm text-slate-600">
        MIT License © {year}{' '}
        <a href="https://parthrb.dev" target="_blank" rel="noopener" class="text-slate-500 hover:text-violet-400 transition-colors">
          Parth Bhawar
        </a>
      </p>
      <p class="text-xs text-slate-700 flex items-center gap-1.5">
        Built with
        <a href="https://astro.build" target="_blank" rel="noopener" class="hover:text-slate-500 transition-colors">Astro</a>
        ·
        <a href="https://gsap.com" target="_blank" rel="noopener" class="hover:text-slate-500 transition-colors">GSAP</a>
        ·
        <a href="https://threejs.org" target="_blank" rel="noopener" class="hover:text-slate-500 transition-colors">Three.js</a>
      </p>
    </div>
  </div>
</footer>
