---
const builtWith = [
  {
    name: 'Claude Code',
    by: 'Anthropic',
    desc: 'AI coding assistant that dramatically accelerated development — architecture decisions, debugging, and writing boilerplate.',
    link: 'https://claude.ai/code',
    icon: '🤖',
    highlight: true,
  },
  {
    name: 'TypeScript',
    by: 'Microsoft',
    desc: 'Type-safe backend and frontend. Prisma + TypeScript made the DB layer painless to refactor.',
    icon: '🔷',
  },
  {
    name: 'Fumadocs',
    by: 'fuma-nama',
    desc: 'Beautiful documentation framework built on Next.js. Powers the full docs site.',
    link: 'https://fumadocs.vercel.app',
    icon: '📚',
  },
  {
    name: 'Vite',
    by: 'Evan You',
    desc: 'Blazing-fast frontend build tooling. HMR during development made iteration loops instant.',
    icon: '⚡',
  },
];

const inspirations = [
  {
    name: 'Coolify',
    desc: 'Great open-source PaaS — but the complexity was overkill for teams who just want git-triggered deploys without the full platform.',
    link: 'https://coolify.io',
  },
  {
    name: 'Dokku',
    desc: 'The minimal philosophy I was aiming for. Showed me that a small tool that does one thing well beats a bloated platform.',
    link: 'https://dokku.com',
  },
  {
    name: 'Caprover',
    desc: 'The dashboard concept — giving a visual interface to server deployments was the right call.',
    link: 'https://caprover.com',
  },
  {
    name: 'GitHub Actions',
    desc: 'The workflow YAML model is brilliant. I wanted the same power but running on a $6/month VPS instead of shared cloud runners.',
  },
];
---

<section id="motivation" class="relative py-28 px-6">
  <!-- Subtle top separator -->
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-violet-500/20 to-transparent"></div>

  <div class="max-w-5xl mx-auto">

    <!-- Why I built this -->
    <div class="grid lg:grid-cols-2 gap-16 items-center mb-24">
      <div class="section-fade">
        <span class="inline-block text-violet-400 text-xs font-bold uppercase tracking-[0.2em] mb-4">About</span>
        <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-6 tracking-tight leading-tight">
          Built from<br /><span class="gradient-text">frustration</span>
        </h2>
        <div class="space-y-4 text-slate-400 leading-relaxed">
          <p>
            I manage 10+ client VPS servers as a freelancer. Every deploy was the same routine: SSH in, <code class="text-violet-300 bg-violet-500/10 px-1 rounded text-xs">git pull</code>, <code class="text-violet-300 bg-violet-500/10 px-1 rounded text-xs">npm run build</code>, copy files, reload Nginx.
          </p>
          <p>
            GitHub Actions costs money I didn't want to spend on small client projects. Jenkins felt like piloting a fighter jet to get groceries. Coolify was brilliant but had too much surface area.
          </p>
          <p>
            I wanted <span class="text-slate-300 font-medium">one dashboard</span> that showed me what deployed when, let me re-trigger a deploy with one click, and streamed logs so I knew if it worked — all running on the server I already had.
          </p>
          <p>
            <span class="text-slate-300 font-medium">DeployManager is that tool.</span>
          </p>
        </div>
      </div>

      <!-- Author card -->
      <div class="section-fade">
        <div class="rounded-2xl glow-border p-8 flex flex-col gap-5">
          <div class="flex items-start gap-4">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-violet-600 to-purple-800 flex items-center justify-center text-2xl font-black text-white shadow-lg shadow-violet-600/25 shrink-0">
              P
            </div>
            <div>
              <h3 class="text-lg font-bold text-white">Parth Bhawar</h3>
              <p class="text-slate-400 text-sm">Freelance developer · VPS enthusiast</p>
              <p class="text-slate-500 text-xs mt-1">Building tools I wish existed</p>
            </div>
          </div>

          <p class="text-slate-400 text-sm leading-relaxed">
            I build web apps for clients and needed a deployment workflow that was simple, cheap, and gave me visibility into what was running on my servers.
          </p>

          <div class="flex flex-wrap gap-3 pt-1">
            <a
              href="https://parthrb.dev"
              target="_blank"
              rel="noopener"
              class="flex items-center gap-2 px-4 py-2 rounded-lg bg-violet-600/15 border border-violet-500/25 text-violet-300 text-sm font-medium hover:bg-violet-600/25 transition-colors"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/>
              </svg>
              parthrb.dev
            </a>
            <a
              href="https://github.com/20parth"
              target="_blank"
              rel="noopener"
              class="flex items-center gap-2 px-4 py-2 rounded-lg glass text-slate-300 text-sm font-medium hover:text-white transition-colors"
            >
              <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              @20parth
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Built with -->
    <div class="mb-20 section-fade">
      <h3 class="text-2xl font-bold text-white mb-2">Built with</h3>
      <p class="text-slate-500 text-sm mb-8">Tools that made development faster and better.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {builtWith.map(({ name, by, desc, link, icon, highlight }) => (
          <div class={`rounded-2xl p-5 flex gap-4 ${highlight ? 'glow-border' : 'glass'}`}>
            <span class="text-2xl shrink-0 mt-0.5">{icon}</span>
            <div>
              <div class="flex items-baseline gap-2 mb-1">
                <span class="font-semibold text-white">{name}</span>
                <span class="text-xs text-slate-500">by {by}</span>
                {highlight && (
                  <span class="text-xs px-1.5 py-0.5 rounded bg-violet-500/15 text-violet-400 border border-violet-500/20">used to build this</span>
                )}
              </div>
              <p class="text-sm text-slate-400 leading-relaxed">{desc}</p>
              {link && (
                <a href={link} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-xs text-violet-400 hover:text-violet-300 mt-2 transition-colors">
                  Visit →
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Inspired by -->
    <div class="section-fade">
      <h3 class="text-2xl font-bold text-white mb-2">Inspired by</h3>
      <p class="text-slate-500 text-sm mb-8">Projects that shaped the design philosophy.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {inspirations.map(({ name, desc, link }) => (
          <div class="glass rounded-xl p-5 flex flex-col gap-2">
            <div class="flex items-center gap-2">
              <h4 class="font-semibold text-white">{name}</h4>
              {link && (
                <a href={link} target="_blank" rel="noopener" class="text-xs text-slate-500 hover:text-slate-300 transition-colors">↗</a>
              )}
            </div>
            <p class="text-sm text-slate-400 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
