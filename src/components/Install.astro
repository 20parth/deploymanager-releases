---
---
<section id="install" class="relative py-28 px-6">
  <!-- Glow -->
  <div
    class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[800px] h-[300px] pointer-events-none"
    style="background: radial-gradient(ellipse, rgba(124,58,237,0.1) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-4xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-14 section-fade">
      <span class="inline-block text-violet-400 text-xs font-bold uppercase tracking-[0.2em] mb-4">Install</span>
      <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight">
        Up and running in <span class="gradient-text">minutes</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-xl mx-auto">
        One command installer handles PostgreSQL, Nginx, SSL, and firewall automatically.
        Choose Docker or bare metal.
      </p>
    </div>

    <!-- Main install terminal -->
    <div class="section-fade terminal-window mb-8">
      <div class="terminal-bar justify-between">
        <div class="flex items-center gap-1.5">
          <span class="terminal-dot bg-red-500/70"></span>
          <span class="terminal-dot bg-yellow-500/70"></span>
          <span class="terminal-dot bg-green-500/70"></span>
          <span class="ml-3 text-xs text-slate-500 font-mono">Ubuntu 22.04 / Debian 12</span>
        </div>
        <button
          id="copy-btn"
          class="flex items-center gap-1.5 text-xs text-slate-400 hover:text-white bg-white/5 hover:bg-white/10 border border-white/8 hover:border-white/15 rounded-md px-3 py-1 transition-all duration-200 font-mono"
        >
          <svg id="copy-icon" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
          <span id="copy-label">Copy</span>
        </button>
      </div>

      <div class="p-6 font-mono text-sm space-y-2.5 leading-relaxed select-all">
        <div class="flex gap-3 items-start">
          <span class="text-violet-400 shrink-0 mt-0.5">$</span>
          <span class="text-slate-200 break-all">curl -fsSL https://deploymanager.parthrb.dev/install.sh -o install.sh</span>
        </div>
        <div class="flex gap-3 items-start">
          <span class="text-violet-400 shrink-0 mt-0.5">$</span>
          <div>
            <span class="text-slate-200">echo </span>
            <span class="text-emerald-300">"b4fd20fe738b0200956bf0710606affd7f1d56514b55c203056f2e5fb6353791  install.sh"</span>
            <span class="text-slate-400"> | sha256sum -c</span>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <span class="text-violet-400 shrink-0 mt-0.5">$</span>
          <span class="text-slate-200">sudo bash install.sh</span>
        </div>
      </div>
    </div>

    <!-- Two method cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10 section-fade">

      <!-- Docker -->
      <div class="rounded-2xl glow-border p-6 flex flex-col gap-4">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🐳</span>
          <div>
            <h3 class="font-semibold text-white">Docker <span class="text-xs font-normal text-emerald-400 ml-1">(recommended)</span></h3>
            <p class="text-xs text-slate-500 mt-0.5">Pre-built images · no build step</p>
          </div>
        </div>
        <p class="text-sm text-slate-400 leading-relaxed">
          Uses <code class="text-violet-300 bg-violet-500/10 px-1 rounded">parthrb/deploymanager-api</code> and <code class="text-violet-300 bg-violet-500/10 px-1 rounded">parthrb/deploymanager-web</code> from Docker Hub. Easiest to update.
        </p>
        <div class="mt-auto font-mono text-xs text-slate-500 bg-black/30 rounded-lg p-3 border border-white/5 space-y-1">
          <div><span class="text-slate-600">→</span> PostgreSQL in container</div>
          <div><span class="text-slate-600">→</span> Nginx on host (port 80/443)</div>
          <div><span class="text-slate-600">→</span> Auto-updates via docker pull</div>
        </div>
      </div>

      <!-- Bare metal -->
      <div class="rounded-2xl glass p-6 flex flex-col gap-4">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🖥️</span>
          <div>
            <h3 class="font-semibold text-white">Bare Metal</h3>
            <p class="text-xs text-slate-500 mt-0.5">Node + PM2 + Nginx</p>
          </div>
        </div>
        <p class="text-sm text-slate-400 leading-relaxed">
          Runs directly on the host filesystem — best when your deploy scripts need direct access to <code class="text-violet-300 bg-violet-500/10 px-1 rounded">/var/www</code> or system services.
        </p>
        <div class="mt-auto font-mono text-xs text-slate-500 bg-black/30 rounded-lg p-3 border border-white/5 space-y-1">
          <div><span class="text-slate-600">→</span> PM2 manages the process</div>
          <div><span class="text-slate-600">→</span> PostgreSQL on host</div>
          <div><span class="text-slate-600">→</span> Full host filesystem access</div>
        </div>
      </div>
    </div>

    <!-- Requirements -->
    <div class="section-fade rounded-2xl glass p-6">
      <h3 class="text-sm font-semibold text-white mb-4 flex items-center gap-2">
        <span class="text-slate-400">Requirements</span>
      </h3>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
        {[
          { label: 'OS', value: 'Ubuntu 22.04 or Debian 12' },
          { label: 'RAM', value: '1 GB minimum' },
          { label: 'CPU', value: '1 vCPU minimum' },
          { label: 'Disk', value: '10 GB free' },
        ].map(({ label, value }) => (
          <div>
            <div class="text-slate-500 text-xs uppercase tracking-wider mb-1">{label}</div>
            <div class="text-slate-300 font-medium">{value}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('copy-btn');
  const label = document.getElementById('copy-label');
  const icon = document.getElementById('copy-icon');

  const COMMANDS = [
    'curl -fsSL https://deploymanager.parthrb.dev/install.sh -o install.sh',
    'echo "b4fd20fe738b0200956bf0710606affd7f1d56514b55c203056f2e5fb6353791  install.sh" | sha256sum -c',
    'sudo bash install.sh',
  ].join('\n');

  btn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(COMMANDS);
      if (label) label.textContent = 'Copied!';
      if (icon) icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>`;
      btn?.classList.add('text-emerald-400', 'border-emerald-500/30');
      setTimeout(() => {
        if (label) label.textContent = 'Copy';
        if (icon) icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>`;
        btn?.classList.remove('text-emerald-400', 'border-emerald-500/30');
      }, 2000);
    } catch {}
  });
</script>
